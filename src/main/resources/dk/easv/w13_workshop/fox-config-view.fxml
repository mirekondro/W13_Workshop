<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.geometry.Insets?>

<BorderPane xmlns="http://javafx.com/javafx"
            xmlns:fx="http://javafx.com/fxml"
            fx:controller="dk.easv.w13_workshop.FoxConfigController"
            styleClass="border-pane">

    <!-- ═══════════════════════  TOP HEADER  ══════════════════════════════ -->
    <top>
        <VBox styleClass="header-box" alignment="CENTER">
            <Label text="🦊  FOX CONFIGURATOR" styleClass="header-title"/>
            <Label text="Professional Orienteering Equipment Setup Tool" styleClass="header-subtitle"/>
        </VBox>
    </top>

    <!-- ═══════════════════════  CENTER CONTENT  ══════════════════════════ -->
    <center>
        <ScrollPane styleClass="content-scroll" fitToWidth="true" vbarPolicy="AS_NEEDED" hbarPolicy="NEVER">
            <VBox styleClass="content-vbox">

                <!-- ── Group Configuration Section ── -->
                <VBox styleClass="section-box">
                    <Label text="🎯  Basic Configuration" styleClass="section-title"/>
                    <HBox spacing="30" alignment="CENTER_LEFT">
                        <VBox spacing="8" minWidth="150">
                            <Label text="Group Number" styleClass="field-label"/>
                            <TextField fx:id="tfGroupNumber" promptText="Enter group number (e.g., 1)"
                                      maxWidth="120" styleClass="text-field"/>
                        </VBox>

                        <VBox spacing="8">
                            <Label text="Communication Mode" styleClass="field-label"/>
                            <HBox spacing="20" alignment="CENTER_LEFT">
                                <RadioButton fx:id="rbApi" text="🌐 API Connection"
                                           styleClass="radio-button"/>
                                <Label text="(http://10.5.10.10:8080)" style="-fx-text-fill: #7f8c8d; -fx-font-size: 12px;"/>
                                <RadioButton fx:id="rbMock" text="🔧 Mock Mode"
                                           styleClass="radio-button"/>
                                <Label text="(Offline Testing)" style="-fx-text-fill: #7f8c8d; -fx-font-size: 12px;"/>
                            </HBox>
                        </VBox>
                    </HBox>
                </VBox>

                <!-- ── Configuration Parameters Section ── -->
                <VBox styleClass="section-box">
                    <Label text="⚙️  Fox Parameters" styleClass="section-title"/>

                    <GridPane styleClass="grid-pane">
                        <columnConstraints>
                            <ColumnConstraints minWidth="180" prefWidth="200"/>
                            <ColumnConstraints hgrow="ALWAYS" minWidth="200"/>
                            <ColumnConstraints minWidth="120" prefWidth="140"/>
                        </columnConstraints>

                        <!-- Header row -->
                        <Label text="Parameter" styleClass="field-label" GridPane.columnIndex="0" GridPane.rowIndex="0"/>
                        <Label text="Value" styleClass="field-label" GridPane.columnIndex="1" GridPane.rowIndex="0"/>
                        <Label text="Actions" styleClass="field-label" GridPane.columnIndex="2" GridPane.rowIndex="0"/>

                        <!-- Test time -->
                        <Label text="🕐 Test Begin Time" styleClass="label" GridPane.columnIndex="0" GridPane.rowIndex="1"/>
                        <TextField fx:id="tfTestTime" promptText="e.g. 1230 (HHMM format)"
                                   styleClass="text-field" GridPane.columnIndex="1" GridPane.rowIndex="1"/>
                        <Button fx:id="btnQueueTest" text="+ Queue" onAction="#onQueueTest"
                               styleClass="queue-button" maxWidth="Infinity"
                               GridPane.columnIndex="2" GridPane.rowIndex="1"/>

                        <!-- Start time -->
                        <Label text="🚀 Hunt Start Time" styleClass="label" GridPane.columnIndex="0" GridPane.rowIndex="2"/>
                        <TextField fx:id="tfStartTime" promptText="e.g. 1300 (HHMM format)"
                                   styleClass="text-field" GridPane.columnIndex="1" GridPane.rowIndex="2"/>
                        <Button fx:id="btnQueueStart" text="+ Queue" onAction="#onQueueStart"
                               styleClass="queue-button" maxWidth="Infinity"
                               GridPane.columnIndex="2" GridPane.rowIndex="2"/>

                        <!-- Stop time -->
                        <Label text="🛑 Hunt Stop Time" styleClass="label" GridPane.columnIndex="0" GridPane.rowIndex="3"/>
                        <TextField fx:id="tfStopTime" promptText="e.g. 1500 (HHMM format)"
                                   styleClass="text-field" GridPane.columnIndex="1" GridPane.rowIndex="3"/>
                        <Button fx:id="btnQueueStop" text="+ Queue" onAction="#onQueueStop"
                               styleClass="queue-button" maxWidth="Infinity"
                               GridPane.columnIndex="2" GridPane.rowIndex="3"/>

                        <!-- Fox ID -->
                        <Label text="🆔 Fox Identifier" styleClass="label" GridPane.columnIndex="0" GridPane.rowIndex="4"/>
                        <ComboBox fx:id="cbFoxId" maxWidth="Infinity" styleClass="combo-box"
                                  GridPane.columnIndex="1" GridPane.rowIndex="4"/>
                        <Button fx:id="btnQueueId" text="+ Queue" onAction="#onQueueId"
                               styleClass="queue-button" maxWidth="Infinity"
                               GridPane.columnIndex="2" GridPane.rowIndex="4"/>

                        <!-- Frequency -->
                        <Label text="📡 Frequency (Hz)" styleClass="label" GridPane.columnIndex="0" GridPane.rowIndex="5"/>
                        <TextField fx:id="tfFrequency" promptText="e.g. 434750 (in Hz)"
                                   styleClass="text-field" GridPane.columnIndex="1" GridPane.rowIndex="5"/>
                        <Button fx:id="btnQueueFreq" text="+ Queue" onAction="#onQueueFreq"
                               styleClass="queue-button" maxWidth="Infinity"
                               GridPane.columnIndex="2" GridPane.rowIndex="5"/>

                        <!-- Period -->
                        <Label text="⏰ Repeat Period (min)" styleClass="label" GridPane.columnIndex="0" GridPane.rowIndex="6"/>
                        <TextField fx:id="tfPeriod" promptText="e.g. 5 (minutes)"
                                   styleClass="text-field" GridPane.columnIndex="1" GridPane.rowIndex="6"/>
                        <Button fx:id="btnQueuePeriod" text="+ Queue" onAction="#onQueuePeriod"
                               styleClass="queue-button" maxWidth="Infinity"
                               GridPane.columnIndex="2" GridPane.rowIndex="6"/>

                        <!-- Fox call -->
                        <Label text="📻 Call Sign (≤15 chars)" styleClass="label" GridPane.columnIndex="0" GridPane.rowIndex="7"/>
                        <TextField fx:id="tfFoxCall" promptText="e.g. OZ7FOX"
                                   styleClass="text-field" GridPane.columnIndex="1" GridPane.rowIndex="7"/>
                        <Button fx:id="btnQueueCall" text="+ Queue" onAction="#onQueueCall"
                               styleClass="queue-button" maxWidth="Infinity"
                               GridPane.columnIndex="2" GridPane.rowIndex="7"/>
                    </GridPane>
                </VBox>

                <!-- ── Command Queue Section ── -->
                <VBox styleClass="section-box">
                    <HBox spacing="16" alignment="CENTER_LEFT">
                        <Label text="📋  Command Queue" styleClass="section-title"/>
                        <Region HBox.hgrow="ALWAYS"/>
                        <Label fx:id="lblPendingCount" text="Pending: 0" styleClass="pending-count"/>
                        <Button fx:id="btnClear" text="Clear All" onAction="#onClear"
                               styleClass="clear-button"/>
                        <Button fx:id="btnSendAll" text="🚀  Execute All Commands" onAction="#onSendAll"
                               styleClass="send-button" disable="true"/>
                    </HBox>

                    <TextArea fx:id="taPendingLog" editable="false" prefHeight="140"
                              promptText="📝 Queued commands will appear here..."
                              wrapText="true" styleClass="text-area"/>
                </VBox>

                <!-- ── Execution Log Section ── -->
                <VBox styleClass="section-box">
                    <Label text="📊  Execution Results" styleClass="section-title"/>
                    <TextArea fx:id="taExecutionLog" editable="false" prefHeight="140"
                              promptText="✅ Command execution results will be displayed here..."
                              wrapText="true" styleClass="text-area"/>
                </VBox>
            </VBox>
        </ScrollPane>
    </center>

    <!-- ═══════════════════════  BOTTOM STATUS BAR  ════════════════════════ -->
    <bottom>
        <HBox styleClass="status-bar" alignment="CENTER_LEFT">
            <Label text="Status:" styleClass="status-label"/>
            <Label fx:id="lblStatus" text="Ready for configuration" styleClass="status-ready"/>
        </HBox>
    </bottom>
</BorderPane>
